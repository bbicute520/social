PORT=5000

# Supabase Postgres connection
DATABASE_URL="postgres://postgres.xxx:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres.xxx:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Clerk Auth integration
CLERK_SECRET_KEY=sk_test_... # Get from Clerk Dashboard
CLERK_PUBLISHABLE_KEY=pk_test_...

# Pusher integration (optional)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Uploadthing integration
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
